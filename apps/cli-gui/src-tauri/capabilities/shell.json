{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "shell-sidecar",
  "description": "Allow executing the bundled aas CLI sidecar",
  "windows": ["main"],
  "permissions": [
    {
      "identifier": "shell:allow-execute",
      "allow": [{ "name": "binaries/aas", "sidecar": true }]
    }
  ]
}
